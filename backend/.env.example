# Application settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
LOG_LEVEL=info

# SQLite database path (relative to backend working dir)
SHIPIQ_DB_PATH=shipiq.db

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://shipiq.abhidev.xyz

# Rate limiting: max calls per IP per window
RATE_LIMIT_CALLS=60
RATE_LIMIT_PERIOD=60
